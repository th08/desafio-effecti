{
    "name": "effecti/erp-contracts",
    "description": "Sistema de gestão de contratos e serviços - Desafio Técnico Effecti",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "nikic/fast-route": "^1.3",
        "illuminate/database": "^11.0",
        "illuminate/events": "^11.0",
        "illuminate/pagination": "^11.0",
        "robmorgan/phinx": "^0.16",
        "vlucas/phpdotenv": "^5.6",
        "rakit/validation": "^1.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "migrate": "phinx migrate -c phinx.php",
        "seed": "phinx seed:run -c phinx.php",
        "rollback": "phinx rollback -c phinx.php"
    }
}

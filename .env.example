# ===========================================
# Configurações de Ambiente - ERP Contratos
# ===========================================

# Ambiente da aplicação (development, production)
APP_ENV=development
APP_DEBUG=true

# ===========================================
# Banco de Dados (PostgreSQL)
# ===========================================
# PostgreSQL roda no Docker Compose.
# DB_HOST e DB_PORT são usados internamente entre containers.
#
# Se a porta 5432 já estiver em uso na sua máquina,
# altere DB_PORT_HOST para 5433 (ou outra porta livre).
# ===========================================
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_PORT_HOST=5432
DB_DATABASE=desafio_effecti
DB_USERNAME=erp_user
DB_PASSWORD=effecti2026!

# ===========================================
# Startup do backend
# ===========================================
AUTO_MIGRATE=true
AUTO_SEED=true

# ===========================================
# CORS - Origens permitidas no frontend
# ===========================================
CORS_ORIGIN=http://localhost:5173

# ===========================================
# API
# ===========================================
API_BASE_URL=http://localhost:8080

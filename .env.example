# ===========================================
# Configurações de Ambiente - ERP Contratos
# ===========================================

# Ambiente da aplicação (development, production)
APP_ENV=development
APP_DEBUG=true

# ===========================================
# Banco de Dados (PostgreSQL)
# ===========================================
# Configure abaixo os dados do seu PostgreSQL local.
# O banco de dados deve ser criado manualmente antes de rodar as migrations.
#
# IMPORTANTE: Para conectar ao PostgreSQL instalado na máquina host
# a partir dos containers Docker, use:
#   - Linux (padrão recomendado): DB_HOST=172.17.0.1
#   - Linux (alternativa): DB_HOST=host.docker.internal
#   - Mac/Windows: DB_HOST=host.docker.internal
#
# Se o PostgreSQL estiver em outra porta (ex: 5433), ajuste DB_PORT.
# ===========================================
DB_CONNECTION=pgsql
DB_HOST=<172.17.0.1> | <host.docker.internal>
DB_PORT=5432
DB_DATABASE=<DB_DATABASE>
DB_USERNAME=<DB_USERNAME>
DB_PASSWORD=<DB_PASSWORD>

# ===========================================
# CORS - Origens permitidas no frontend
# ===========================================
CORS_ORIGIN=http://localhost:5173

# ===========================================
# API
# ===========================================
API_BASE_URL=http://localhost:8080
